# Backend FastAPI (opcional si usas el proxy integrado)
# Si NO defines NEXT_PUBLIC_API_BASE_URL, el front usa /api/upstream → rewrite a API_UPSTREAM_URL (next.config.js).
# Así /auth/me no se confunde con rutas de Next en :3000.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8501
#
# Destino del rewrite (solo servidor Next; por defecto http://127.0.0.1:8501)
# API_UPSTREAM_URL=http://127.0.0.1:8501

# Authentication
NEXT_PUBLIC_JWT_SECRET=your-secret-key-here

# Optional: Analytics, Sentry, etc.
# NEXT_PUBLIC_SENTRY_DSN=
