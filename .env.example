# Copia a .env y ajusta valores. El archivo .env no se versiona.

# PostgreSQL (SQLAlchemy + psycopg 3). Base requerida: vgd_dwh_prod_migracion.
# Si la URL termina en /postgres o sin nombre de base, la app la reescribe automáticamente a vgd_dwh_prod_migracion.
DWH_URL=postgresql+psycopg://postgres:TU_CLAVE@127.0.0.1:5432/vgd_dwh_prod_migracion

# Ollama local (recomendado para SQL: qwen2.5-coder:7b; ollama pull qwen2.5-coder:7b)
LLM_ENDPOINT=http://127.0.0.1:11434
LLM_MODEL=qwen2.5-coder:7b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=180

MAX_ROWS=200

# Interfaz web Streamlit: 1/true = abrir con modo desarrollo (mostrar SQL y JSON).
# AGENTE_DWH_DEVELOPER_UI=0

# Contexto de esquema para el LLM (regenerar con: python scripts/export_dwh_schema_hint.py)
SCHEMA_HINT_FILE=./schema_hint_dwh.txt

# Catálogo JSON (export del esquema; referencia para scripts y contexto LLM).
# DWH_SCHEMA_CATALOG_FILE=./dwh_schema_catalog.json

# Perfil de prompts: por defecto vgd. Usa default solo en entornos excepcionales.
# AGENTE_DWH_LLM_PROFILE=

# Solo si la URL debe apuntar a otra base (tests, réplica): permite omitir la comprobación del nombre de BD.
# AGENTE_DWH_SKIP_DB_NAME_CHECK=

# Desactiva la prevalidación COUNT() en PostgreSQL (no recomendado).
# AGENTE_DWH_DISABLE_SQL_GUARD=
