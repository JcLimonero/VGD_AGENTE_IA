# Copia a .env y ajusta valores. El archivo .env no se versiona.

# --- Origen operativo MySQL (ETL / referencia; el agente usa solo DWH_URL en PostgreSQL) ---
# Host típico documentado: 74.208.78.55:3306, base: vgd_dwh_prod.
# Tablas de negocio: customers, agencies, invoices, orders, services, inventory, customer_vehicle.
# URL de ejemplo (instala driver: pip install pymysql; grupo opcional: pip install -e ".[mysql_migration]"):
# MYSQL_SOURCE_URL=mysql+pymysql://USUARIO:CLAVE@74.208.78.55:3306/vgd_dwh_prod
# O variables sueltas: MYSQL_HOST MYSQL_PORT MYSQL_USER MYSQL_PASSWORD MYSQL_DATABASE
#
# Migración a Postgres local (bd dwh): python scripts/migrate_mysql_to_local_dwh.py
# PostgreSQL admin (base postgres) para crear la BD; si no, se usa DWH_URL con nombre sustituido por postgres:
# LOCAL_PG_ADMIN_URL=postgresql+psycopg://USUARIO:CLAVE@127.0.0.1:5433/postgres

# PostgreSQL (SQLAlchemy + psycopg 3). Bases admitidas sin SKIP: vgd_dwh_prod_migracion o dwh (local).
# Si la URL termina en /postgres o sin nombre de base, la app la reescribe a vgd_dwh_prod_migracion.
# DWH_URL=postgresql+psycopg://postgres:TU_CLAVE@127.0.0.1:5432/vgd_dwh_prod_migracion
DWH_URL=postgresql+psycopg://postgres:TU_CLAVE@127.0.0.1:5432/dwh

# Ollama local (recomendado para SQL: qwen2.5-coder:7b; ollama pull qwen2.5-coder:7b)
LLM_ENDPOINT=http://127.0.0.1:11434
LLM_MODEL=qwen2.5-coder:7b

# === NUEVA CONFIGURACIÓN DE PLATAFORMA ===

# JWT para autenticación de usuarios
JWT_SECRET=your-super-secret-key-change-in-production-minimum-32-chars

# Base de datos de la plataforma (PostgreSQL): platform_users, saved_queries, dashboards (ver create_platform_tables.sql)
PLATFORM_DB_URL=postgresql://vgd_user:vgd_pass@localhost:5432/vgd_platform

# Configuración del servidor API
API_HOST=0.0.0.0
API_PORT=8501

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=180

MAX_ROWS=200

# Interfaz web Streamlit: 1/true = abrir con modo desarrollo (mostrar SQL y JSON).
# AGENTE_DWH_DEVELOPER_UI=0

# Contexto de esquema para el LLM (regenerar con: python scripts/export_dwh_schema_hint.py)
SCHEMA_HINT_FILE=./schema_hint_dwh.txt
# Incluye muestras de valores categóricos (status/type/stage) en schema_hint_dwh.txt
AGENTE_DWH_INCLUDE_PROFILED_VALUES=1
# Máximo de valores de muestra por columna perfilada
AGENTE_DWH_PROFILED_VALUES_LIMIT=12
# 0 recomendado: oculta columnas operativas de integración (Salesforce) en el hint
AGENTE_DWH_INCLUDE_NOISE_COLUMNS=0

# Catálogo JSON (export del esquema; referencia para scripts y contexto LLM).
# DWH_SCHEMA_CATALOG_FILE=./dwh_schema_catalog.json

# Perfil de prompts: por defecto vgd. Usa default solo en entornos excepcionales.
# AGENTE_DWH_LLM_PROFILE=

# Solo si la URL debe apuntar a otra base (tests, réplica): permite omitir la comprobación del nombre de BD.
# AGENTE_DWH_SKIP_DB_NAME_CHECK=

# Desactiva la prevalidación COUNT() en PostgreSQL (no recomendado).
# AGENTE_DWH_DISABLE_SQL_GUARD=

# Fuerza que el agente use solo vistas homologadas h_* en FROM/JOIN.
# AGENTE_DWH_ONLY_H_TABLES=1
