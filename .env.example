# Copia a .env y ajusta valores. El archivo .env no se versiona.

# PostgreSQL (SQLAlchemy + psycopg 3)
DWH_URL=postgresql+psycopg://postgres:TU_CLAVE@127.0.0.1:5432/postgres
DEMO_DWH_URL=postgresql+psycopg://postgres:TU_CLAVE@127.0.0.1:5432/postgres

# Ollama local (recomendado para SQL: qwen2.5-coder:7b; ollama pull qwen2.5-coder:7b)
LLM_ENDPOINT=http://127.0.0.1:11434
LLM_MODEL=qwen2.5-coder:7b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=180

MAX_ROWS=200

# Interfaz web Streamlit: 1/true = abrir con modo desarrollo (mostrar SQL y JSON). Por defecto demo solo resultados.
# AGENTE_DWH_DEVELOPER_UI=0

# Recomendado para el LLM (tabla customers, MVs, etc.)
SCHEMA_HINT_FILE=./schema_hint_demo.txt
